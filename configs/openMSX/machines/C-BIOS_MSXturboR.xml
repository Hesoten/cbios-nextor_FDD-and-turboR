<?xml version="1.0" ?>
<!DOCTYPE msxconfig SYSTEM 'msxconfig2.dtd'>
<msxconfig>

  <info>
    <manufacturer>C-BIOS</manufacturer>
    <code>MSXturboR</code>
    <release_year>2026</release_year>
    <description>An MSX turbo R machine using C-BIOS 0.29+, with MSX-MUSIC, MSX-MIDI, PCM and a Japanese keyboard layout.</description>
    <type>MSXturboR</type>
    <region>jp</region>
  </info>

  <MapperReadBackBits>largest</MapperReadBackBits>

  <CassettePort/>

  <devices>

    <primary slot="0">

      <secondary slot="0">
        <ROM id="C-BIOS Main ROM turbo R JP">
          <mem base="0x0000" size="0x8000"/>
          <rom>
            <!--sha1:cbios_main_msxtr_jp.rom-->
            <filename>cbios_main_msxtr_jp.rom</filename>
          </rom>
        </ROM>

        <ROM id="C-BIOS Logo ROM">
          <mem base="0x8000" size="0x4000"/>
          <rom>
            <!--sha1:cbios_logo_msx2+.rom-->
            <filename>cbios_logo_msx2+.rom</filename>
          </rom>
        </ROM>
      </secondary>

      <secondary slot="2">
        <MSX-MUSIC id="C-BIOS MSX-MUSIC">
          <mem base="0x4000" size="0x4000"/>
          <io base="0x7C" num="2" type="O"/>
          <rom>
            <!--sha1:cbios_music.rom-->
            <filename>cbios_music.rom</filename>
          </rom>
          <sound>
            <volume>9000</volume>
          </sound>
        </MSX-MUSIC>
      </secondary>

    </primary>

    <primary external="true" slot="1"/>

    <primary external="true" slot="2"/>

    <primary slot="3">

      <secondary slot="0">
        <MemoryMapper id="Main RAM">
          <mem base="0x0000" size="0x10000"/>
          <size>512</size>
        </MemoryMapper>
      </secondary>

      <secondary slot="1">
        <ROM id="C-BIOS Sub ROM">
          <mem base="0x0000" size="0x4000"/>
          <rom>
            <!--sha1:cbios_sub.rom-->
            <filename>cbios_sub.rom</filename>
          </rom>
        </ROM>
      </secondary>

    </primary>

    <Kanji id="Kanji ROM">
      <io base="0xD8" num="4"/>
      <rom>
        <sha1>f979ad20850a5c1673bc2c5943f470db6925eb50</sha1>
        <filename>KANJI.rom</filename>
      </rom>
    </Kanji>

    <S1990 id="S1990">
      <io base="0xE4" num="2"/>
    </S1990>

    <T9769 id="T9769">
      <subtype>C</subtype>
    </T9769>

    <PPI id="ppi">
      <io base="0xA8" num="4"/>
      <sound>
        <volume>16000</volume>
      </sound>
      <keyboard_type>jp_jis</keyboard_type>
      <has_keypad>true</has_keypad>
      <has_yesno_keys>true</has_yesno_keys>
      <key_ghosting_sgc_protected>false</key_ghosting_sgc_protected>
      <code_kana_locks>true</code_kana_locks>
      <graph_locks>false</graph_locks>
    </PPI>

    <VDP id="VDP">
      <io base="0x98" num="4" type="O"/>
      <io base="0x98" num="2" type="I"/>
      <version>V9958</version>
      <vram>128</vram>
    </VDP>

    <PSG id="PSG">
      <io base="0xA0" num="4" type="IO"/>
      <sound>
        <volume>21000</volume>
      </sound>
      <keyboardlayout>JIS</keyboardlayout>
      <mirrored_registers>false</mirrored_registers>
      <ignorePortDirections>true</ignorePortDirections>
    </PSG>

    <RTC id="Real time clock">
      <io base="0xB4" num="2" type="O"/>
      <io base="0xB5" num="1" type="I"/>
      <sramname>cbios-msxtr.cmos</sramname>
    </RTC>

    <PrinterPort id="Printer Port">
      <io base="0x90" num="2"/>
    </PrinterPort>

    <E6Timer id="Turbo-R timer">
      <io base="0xE6" num="2"/>
    </E6Timer>

    <ResetStatusRegister id="Reset Status register">
      <io base="0xF4" num="1"/>
      <inverted>false</inverted>
    </ResetStatusRegister>

    <TurboRPause id="TurboRPause">
      <io base="0xA7" num="1"/>
    </TurboRPause>

    <TurboRPCM id="PCM">
      <io base="0xA4" num="2"/>
      <sound>
        <volume>21000</volume>
      </sound>
    </TurboRPCM>

    <MSX-MIDI id="MSX-Midi">
      <io base="0xE8" num="8"/>
    </MSX-MIDI>

  </devices>

</msxconfig>
